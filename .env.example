# ╔══════════════════════════════════════════════════════════════════╗
# ║  DeFi Mullet Hackathon — Yield Builder                         ║
# ║  Put your API keys and IDs here. Copy this file to .env.local  ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── 1. LI.FI Earn API ───────────────────────────────────────────
# Get your integrator ID at: https://li.fi/plans/
# This is REQUIRED — every Earn API call needs it.
NEXT_PUBLIC_LIFI_INTEGRATOR_ID=9510b872-7535-4384-850c-2be1f00d913a.443f499a-98c4-40ee-97b7-704f8b958e0d #your-integrator-id-here

# Earn API base URL (update if LI.FI publishes a different endpoint)
NEXT_PUBLIC_LIFI_API_BASE=https://li.fi/v1

# ─── 2. WalletConnect ────────────────────────────────────────────
# Get a free Project ID at: https://cloud.walletconnect.com
# Create a project → copy the Project ID → paste below.
# This is REQUIRED for the wallet connect modal to work.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=0x81858B29AaF515B37a9f6C93F1029CFE28c6D5CC #your-walletconnect-project-id-here

# ─── 3. RPC Providers (Optional but recommended) ─────────────────
# Sign up free at https://www.alchemy.com or https://infura.io
# Without these, the app uses default public RPCs (slower, rate-limited).
#
# Alchemy: Dashboard → Create App → select chain → copy API key
# Infura:  Dashboard → Create Project → copy Project ID
#
# You only need keys for chains you want to support.
# Leave blank to use public fallback RPCs.

NEXT_PUBLIC_ALCHEMY_API_KEY=bZYZixJ7VEXdNjXiqSjQT #your-alchemy-key-here
# OR use Infura instead:
# NEXT_PUBLIC_INFURA_PROJECT_ID=your-infura-project-id-here

# ─── 4. Optional: Extra APIs ─────────────────────────────────────
# These are NOT required but can enhance your project.

# CoinGecko (for USD prices) — free tier needs no key
# NEXT_PUBLIC_COINGECKO_API_KEY=

# DefiLlama — completely free, no key needed
# (used automatically if you add historical APY charts)
